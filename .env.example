# Hades Desktop AI Agent - Environment Configuration Example
# Copy this file to '.env' and fill in your API keys. Do NOT commit the '.env' file to Git!

# Google Gemini API Key - Get yours at: https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Tavily Search API Key (Used for AI Search/Research capabilities) - Get yours at: https://tavily.com/
VITE_TAVILY_API_KEY=your_tavily_api_key_here
