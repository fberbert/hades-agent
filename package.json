{
  "name": "hades-agent",
  "version": "1.0.0",
  "description": "Transparent desktop AI assistant with chat, transcription, and local task tools.",
  "main": "main.js",
  "scripts": {
    "dev:react": "vite",
    "dev:electron": "wait-on http://localhost:3000 && electron .",
    "dev:electron:linux": "wait-on http://localhost:3000 && electron --no-sandbox .",
    "dev:win": "taskkill /F /IM electron.exe 2>nul & npx kill-port 3000 && concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:linux": "npx kill-port 3000 && concurrently \"npm run dev:react\" \"npm run dev:electron:linux\"",
    "dev": "npm run dev:win",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:watch": "vitest",
    "smoke:linux": "bash scripts/linux-smoke-check.sh",
    "smoke:linux:runtime": "bash scripts/linux-runtime-smoke.sh",
    "build:app": "vite build",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux AppImage deb",
    "package": "npm run package:win",
    "dist:win": "vite build && electron-builder --win",
    "dist:linux": "vite build && electron-builder --linux AppImage deb",
    "dist": "npm run dist:win"
  },
  "build": {
    "appId": "com.victorl.hades",
    "productName": "Hades Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*",
      "prompts/**/*",
      "main.js",
      "preload.js",
      "translation-worker.js",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "icon": "public/icon/hades-tray-icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/icon",
      "category": "Utility",
      "maintainer": "fberbert <fberbert@users.noreply.github.com>",
      "artifactName": "Hades-Agent-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "Hades-Agent-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Hades-Agent-Setup-${version}.exe"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "figlet": "^1.11.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "to-ico": "^1.1.5",
    "vite": "^8.0.11",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "@google-cloud/speech": "^7.3.1",
    "@google/genai": "^2.2.0",
    "@google/generative-ai": "^0.24.1",
    "@vitalets/google-translate-api": "^9.2.1",
    "axios": "^1.16.0",
    "electron-log": "^5.4.4",
    "google-translate-api-browser": "^5.0.0",
    "lucide-react": "^1.14.0",
    "react-hotkeys-hook": "^5.3.2",
    "react-markdown": "^10.1.0",
    "recordrtc": "^5.6.2",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "turndown": "^7.2.4",
    "ws": "^8.20.0"
  }
}
